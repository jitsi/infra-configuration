unclassified:
  location:
    # Canonical root URL drives the SAML Assertion Consumer Service URL
    # (<url>/securityRealm/finishLogin). Set explicitly so it does not depend
    # on the baked-in casc.yaml's handling of the JENKINS_URL env var.
    url: "{{ jenkins_root_url }}"
jenkins:
  securityRealm:
    saml:
      binding: "urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST"
      idpMetadataConfiguration:
        xml: "${readFile:/home/jenkins/secrets/idp-metadata.xml}"
      displayNameAttributeName: "${SAML_DISPLAY_NAME_ATTR:-{{ jenkins_saml_display_name_attr }}}"
      emailAttributeName: "${SAML_EMAIL_ATTR:-{{ jenkins_saml_email_attr }}}"
      groupsAttributeName: "${SAML_GROUPS_ATTR:-{{ jenkins_saml_groups_attr }}}"
      usernameAttributeName: "${SAML_USERNAME_ATTR:-{{ jenkins_saml_username_attr }}}"
      usernameCaseConversion: "lowercase"
      maximumAuthenticationLifetime: 86400
  authorizationStrategy:
    loggedInUsersCanDoAnything:
      allowAnonymousRead: false
